{
	"$schema": "./node_modules/wrangler/config-schema.json",
	"compatibility_date": "2026-06-19",
	"compatibility_flags": ["global_fetch_strictly_public"],
	"name": "pronouns",
	"main": "@astrojs/cloudflare/entrypoints/server",
	"assets": {
		"directory": "./dist",
		"binding": "ASSETS"
	},
	"observability": {
		"enabled": true
	},
	"d1_databases": [
		{
			"binding": "DB",
			"database_name": "pronouns-db",
			"database_id": "8937406f-5ffa-4d17-803c-fb9381dee217"
		}
	]
}